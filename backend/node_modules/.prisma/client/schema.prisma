datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id       Int    @id @default(autoincrement())
  email    String @unique
  password String
  name     String
}

model Zone {
  id          Int    @id @default(autoincrement())
  name        String
  type        String // RED, YELLOW, GREEN
  coordinates Json // GeoJSON Polygon
  maxAltitude Int
}
